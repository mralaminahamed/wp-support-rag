# WP Plugin Support Desk RAG — environment template.
# Copy to `.env` and fill secrets. All keys are optional in development;
# defaults live in app/config.py. Prefix is WPRAG_.

# --- Service ---
WPRAG_ENVIRONMENT=development
WPRAG_LOG_LEVEL=INFO

# --- Datastores ---
WPRAG_DATABASE_DSN=postgresql+asyncpg://wprag:wprag@localhost:5432/wprag
WPRAG_REDIS_DSN=redis://localhost:6379/0

# --- Providers ---
WPRAG_DEFAULT_PROVIDER=anthropic
WPRAG_ANTHROPIC_API_KEY=
WPRAG_OPENAI_API_KEY=
WPRAG_OLLAMA_BASE_URL=http://localhost:11434

# --- Embedding / dimensionality (ADR-002) ---
WPRAG_EMBED_MODEL=text-embedding-3-large
WPRAG_DIMENSIONALITY_MODE=halfvec_3072

# --- Security ---
WPRAG_ADMIN_BEARER_TOKEN=
WPRAG_CORS_ORIGINS=["*"]
